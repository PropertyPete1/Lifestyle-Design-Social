{
  "name": "real-estate-auto-posting-backend",
  "version": "1.0.0",
  "description": "Complete TypeScript SaaS Backend for Real Estate Auto-Posting App",
  "main": "dist/app.js",
  "scripts": {
    "start": "node dist/app.js",
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "db:setup": "ts-node src/scripts/setup-db.ts",
    "db:migrate": "ts-node src/scripts/migrate.ts",
    "db:seed": "ts-node src/scripts/seed.ts",
    "db:reset": "ts-node src/scripts/reset.ts",
    "db:backup": "ts-node src/scripts/backup.ts",
    "docker:build": "docker build -t real-estate-autopost-api .",
    "docker:run": "docker run -p 3001:3001 real-estate-autopost-api",
    "deploy:staging": "npm run build && npm run deploy:staging:execute",
    "deploy:production": "npm run build && npm run deploy:production:execute"
  },
