# ========================================
# PRODUCTION - Real Estate Auto-Posting App
# ========================================

# Server Configuration
NODE_ENV=production
PORT=5001

# JWT Configuration (⚠️ CHANGE IN PRODUCTION)
JWT_SECRET=your-production-jwt-secret-minimum-32-characters

# Database Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/auto_posting_prod?retryWrites=true&w=majority

# ========================================
# AI Video Generation APIs
# ========================================

# RunwayML API (Primary AI Video Generation)
RUNWAYML_API_KEY=your-production-runwayml-api-key

# Pika Labs API (Secondary AI Video Generation)
PIKA_API_KEY=your-production-pika-api-key

# Kaiber API (Alternative AI Video Generation)
KAIBER_API_KEY=your-production-kaiber-api-key

# Stability AI API (Image Generation)
STABILITY_API_KEY=your-production-stability-api-key

# OpenAI API (Caption Generation & AI Services)
OPENAI_API_KEY=your-production-openai-api-key

# ========================================
# Social Media Platform APIs
# ========================================

# Instagram Graph API
INSTAGRAM_APP_ID=your-production-instagram-app-id
INSTAGRAM_APP_SECRET=your-production-instagram-app-secret
INSTAGRAM_ACCESS_TOKEN=your-production-instagram-access-token
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=your-production-webhook-verify-token

# TikTok Content Posting API
TIKTOK_CLIENT_KEY=your-production-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-production-tiktok-client-secret

# YouTube Data API v3
YOUTUBE_CLIENT_ID=your-production-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-production-youtube-client-secret
YOUTUBE_API_KEY=your-production-youtube-api-key

# ========================================
# Music & Audio APIs
# ========================================

# Spotify API (Music Recommendations)
SPOTIFY_CLIENT_ID=your-production-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-production-spotify-client-secret

# ========================================
# Email & Notifications
# ========================================

# Email Service (SendGrid/SMTP)
SENDGRID_API_KEY=your-production-sendgrid-api-key
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-production-sendgrid-api-key

# Notification Service
PUSH_NOTIFICATION_KEY=your-production-push-notification-key

# ========================================
# File Storage & CDN
# ========================================

# AWS S3 (Video/Image Storage)
AWS_ACCESS_KEY_ID=your-production-aws-access-key
AWS_SECRET_ACCESS_KEY=your-production-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=auto-posting-app-production

# Cloudinary (Alternative CDN)
CLOUDINARY_CLOUD_NAME=your-production-cloud-name
CLOUDINARY_API_KEY=your-production-cloudinary-api-key
CLOUDINARY_API_SECRET=your-production-cloudinary-api-secret

# ========================================
# Analytics & Monitoring
# ========================================

# Google Analytics
GA_TRACKING_ID=your-production-ga-tracking-id

# Sentry Error Tracking
SENTRY_DSN=your-production-sentry-dsn

# Application Monitoring
APP_INSIGHTS_KEY=your-production-app-insights-key

# ========================================
# Security & Rate Limiting
# ========================================

# CORS Origins (comma-separated)
CORS_ORIGINS=https://your-frontend-domain.vercel.app,https://your-custom-domain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security Headers
HELMET_CSP_ENABLED=true

# ========================================
# Feature Flags
# ========================================

# AI Features
AI_SERVICES_ENABLED=true
CARTOON_GENERATION_ENABLED=true
VIRAL_OPTIMIZATION_ENABLED=true

# Platform Features
MULTI_PLATFORM_POSTING=true
ADVANCED_ANALYTICS=true
TEAM_COLLABORATION=true

# Development Features (disable in production)
TEST_MODE_ENABLED=false
DEBUG_LOGGING=false
ENABLE_DEV_ROUTES=false

# ========================================
# Deployment Configuration
# ========================================

# Frontend URL
FRONTEND_URL=https://your-frontend-domain.vercel.app

# Backend URL
BACKEND_URL=https://your-backend-domain.onrender.com

# Mobile App Deep Links
MOBILE_APP_URL_SCHEME=autopostingapp

# ========================================
# Database Backup & Recovery
# ========================================

# MongoDB Backup
DB_BACKUP_ENABLED=true
DB_BACKUP_FREQUENCY=daily
DB_BACKUP_RETENTION_DAYS=30

# ========================================
# Legal & Compliance
# ========================================

# Privacy Policy URL
PRIVACY_POLICY_URL=https://your-domain.com/privacy

# Terms of Service URL
TERMS_OF_SERVICE_URL=https://your-domain.com/terms

# Contact Information
SUPPORT_EMAIL=support@your-domain.com
ADMIN_EMAIL=admin@your-domain.com 