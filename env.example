# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/auto-posting-app

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-here

# OpenAI API
OPENAI_API_KEY=your-openai-api-key-here

# Twitter API (v2)
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_SECRET=your-twitter-access-secret
TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# Instagram API
INSTAGRAM_USERNAME=your-instagram-username
INSTAGRAM_PASSWORD=your-instagram-password

# File Upload
MAX_FILE_SIZE=100000000
UPLOAD_PATH=./uploads

# AI Content Generation
AI_MODEL=gpt-4
MAX_TOKENS=500

# Optimal Posting Times (24-hour format)
OPTIMAL_TIMES_TWITTER=09:00,12:00,15:00,18:00,20:00
OPTIMAL_TIMES_INSTAGRAM=08:00,11:00,14:00,17:00,19:00,21:00

# Timezone
TIMEZONE=America/New_York

# Camera Roll Path (for auto-posting)
CAMERA_ROLL_PATH=/Users/peterallen/Pictures/Camera Roll 