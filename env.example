# ========================================
# Real Estate Auto-Posting App - Environment Configuration
# ========================================

# Server Configuration
NODE_ENV=development
PORT=5001

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production

# Database Configuration
MONGODB_URI="mongodb+srv://username:password@cluster0.mongodb.net/auto_posting_app?retryWrites=true&w=majority"

# ========================================
# AI Video Generation APIs
# ========================================

# RunwayML API (Primary AI Video Generation)
RUNWAYML_API_KEY=your-runwayml-api-key-here

# Alternative AI Video Generation APIs
PIKA_API_KEY=your-pika-labs-api-key-here
KAIBER_API_KEY=your-kaiber-api-key-here
STABILITY_API_KEY=your-stability-ai-api-key-here

# OpenAI API (for AI features and caption generation)
OPENAI_API_KEY=your-openai-api-key-here

# ========================================
# Social Media Platform APIs
# ========================================

# Instagram API Configuration
INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_APP_SECRET=your-instagram-app-secret
INSTAGRAM_REDIRECT_URI=http://localhost:5001/oauth/instagram/callback

# TikTok API Configuration
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret
TIKTOK_REDIRECT_URI=http://localhost:5001/oauth/tiktok/callback

# YouTube API Configuration
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
YOUTUBE_REDIRECT_URI=http://localhost:5001/oauth/youtube/callback

# Twitter API Configuration
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_SECRET=your-twitter-access-secret
TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# ========================================
# File Upload and Storage Configuration
# ========================================

# File Upload Configuration
MAX_FILE_SIZE=100000000
UPLOAD_PATH=./uploads

# ========================================
# Application Configuration
# ========================================

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=1000

# Logging
LOG_LEVEL=info

# ========================================
# Real Estate Specific Configuration
# ========================================

# Optimal Posting Times (24-hour format)
OPTIMAL_TIMES_INSTAGRAM=08:00,11:00,14:00,17:00,19:00,21:00
OPTIMAL_TIMES_TIKTOK=09:00,12:00,15:00,18:00,20:00,22:00
OPTIMAL_TIMES_YOUTUBE=10:00,13:00,16:00,19:00,21:00

# Timezone
TIMEZONE=America/New_York

# Real Estate Market Configuration
DEFAULT_MARKET_AREA=Central Texas
DEFAULT_PRICE_RANGE=250000-750000

# ========================================
# AI Content Generation Configuration
# ========================================

# AI Model Configuration
AI_MODEL=gpt-4
MAX_TOKENS=500

# Caption Generation Settings
CAPTION_MAX_LENGTH=2200
HASHTAG_LIMIT=30

# Video Processing Settings
VIDEO_MAX_DURATION=60
VIDEO_MAX_FILE_SIZE=100

# ========================================
# Scheduling and Automation
# ========================================

# Auto-posting frequency (posts per day)
POSTS_PER_DAY=3

# Content alternation (real-estate vs cartoon ratio)
CONTENT_RATIO_REAL_ESTATE=60
CONTENT_RATIO_CARTOON=40

# Engagement tracking
TRACK_ENGAGEMENT=true
ENGAGEMENT_ANALYSIS_DAYS=30

# ========================================
# Development and Testing
# ========================================

# Test Mode (set to true for development)
TEST_MODE=false

# Debug Mode
DEBUG_MODE=false

# Mock API Responses (for development without real API keys)
MOCK_SOCIAL_MEDIA_APIS=false
MOCK_AI_APIS=false

# ========================================
# Security Configuration
# ========================================

# Session Configuration
SESSION_SECRET=your-session-secret-key-here

# API Key Encryption
ENCRYPTION_KEY=your-encryption-key-for-stored-tokens

# ========================================
# Monitoring and Analytics
# ========================================

# Analytics Configuration
ANALYTICS_ENABLED=true
ANALYTICS_RETENTION_DAYS=90

# Performance Monitoring
PERFORMANCE_MONITORING=true
ERROR_REPORTING=true

# Health Check Configuration
HEALTH_CHECK_INTERVAL=300000

# ========================================
# Backup and Recovery
# ========================================

# Database Backup
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400000
BACKUP_RETENTION_DAYS=30

# ========================================
# Email Configuration (for notifications)
# ========================================

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# Notification Settings
NOTIFY_ON_ERRORS=true
NOTIFY_ON_SUCCESS=false
ADMIN_EMAIL=admin@yourdomain.com 