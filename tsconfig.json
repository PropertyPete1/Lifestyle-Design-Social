// File path: tsconfig.json

// 🛠️ Instructions:
// Replace the contents of your root-level tsconfig.json file with the block below.
// This removes the unused "electron-main.ts" and includes only relevant folders for your app.

{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "lib": ["es2020"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "removeComments": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "backend",
    "frontend",
    "lib",
    "scripts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}